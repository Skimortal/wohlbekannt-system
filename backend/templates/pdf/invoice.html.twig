<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
  @page { size: A4; }
  * { box-sizing: border-box; }
  html, body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #0e1214; font-size: 10.5px; line-height: 1.45; margin: 0; }
  .muted { color: #6b7176; }
  .right { text-align: right; }
  .nums { font-variant-numeric: tabular-nums; }
  .top { display: flex; justify-content: space-between; align-items: flex-start; }
  .issuer-line { font-size: 8px; color: #6b7176; margin-bottom: 28px; }
  .logo { height: 54px; }
  .meta { width: 100%; border-collapse: collapse; }
  .meta td { padding: 1px 0; vertical-align: top; }
  .meta .label { color: #6b7176; padding-right: 16px; }
  .addresses { display: flex; justify-content: space-between; gap: 24px; margin-top: 8px; }
  .recipient { max-width: 60%; }
  h1 { font-size: 18px; font-weight: 600; letter-spacing: -0.2px; margin: 26px 0 4px; }
  .subtitle { color: #6b7176; margin-bottom: 14px; }
  .intro { white-space: pre-line; margin-bottom: 16px; }
  table.items { width: 100%; border-collapse: collapse; margin-top: 6px; }
  table.items thead th { text-align: left; font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.4px; color: #3a3f42; border-bottom: 1px solid #0e1214; padding: 6px 6px; }
  table.items thead th.r { text-align: right; }
  table.items td { padding: 9px 6px; vertical-align: top; border-bottom: 1px solid #ece8e2; }
  .pos { width: 34px; color: #3a3f42; }
  .col-qty { width: 88px; }
  .col-price { width: 92px; }
  .col-total { width: 100px; }
  .item-title { font-weight: 600; }
  .item-desc { white-space: pre-line; color: #3a3f42; margin-top: 2px; }
  .tax-note { font-size: 8px; color: #6b7176; }
  .totals { width: 52%; margin-left: auto; margin-top: 14px; border-collapse: collapse; }
  .totals td { padding: 5px 6px; }
  .totals .t-label { color: #3a3f42; }
  .totals tr.grand td { font-weight: 700; border-top: 1px solid #0e1214; }
  .legal { margin-top: 14px; font-size: 9px; color: #3a3f42; }
  .payinfo { margin-top: 18px; padding: 10px 12px; background: #faf3ea; border: 1px solid #f3e6d6; border-radius: 6px; font-size: 9.5px; }
  .outro { white-space: pre-line; margin-top: 22px; }
</style>
</head>
<body>
  {% set title = invoice.type.value == 'credit_note' ? 'Gutschrift' : (invoice.type.value == 'cancellation' ? 'Stornorechnung' : 'Rechnung') %}

  <div class="top">
    <div>
      <div class="issuer-line">
        {{ company.legalName }} &nbsp;·&nbsp; {{ company.address.street }} &nbsp;·&nbsp;
        {{ company.address.postalCode }} {{ company.address.city }}
      </div>
    </div>
    {% if logoName %}<img class="logo" src="{{ logoName }}" alt="{{ company.legalName }}">{% endif %}
  </div>

  <div class="addresses">
    <div class="recipient">
      <strong>{{ invoice.recipientName }}</strong><br>
      {% if invoice.recipientAddress.street %}{{ invoice.recipientAddress.street }}<br>{% endif %}
      {% if invoice.recipientAddress.postalCode or invoice.recipientAddress.city %}{{ invoice.recipientAddress.postalCode }} {{ invoice.recipientAddress.city }}<br>{% endif %}
      {{ invoice.recipientAddress.countryCode == 'AT' ? 'Österreich' : invoice.recipientAddress.countryCode }}
    </div>
    <div style="min-width: 240px;">
      <table class="meta">
        <tr><td class="label">{{ title }}-Nr.</td><td class="right">{{ invoice.number ?? 'Entwurf' }}</td></tr>
        <tr><td class="label">Datum</td><td class="right">{{ invoice.issueDate|date('d.m.Y') }}</td></tr>
        {% if invoice.dueDate and invoice.type.value == 'invoice' %}<tr><td class="label">Fällig bis</td><td class="right">{{ invoice.dueDate|date('d.m.Y') }}</td></tr>{% endif %}
        {% if invoice.servicePeriodStart %}<tr><td class="label">Leistungszeitraum</td><td class="right">{{ invoice.servicePeriodStart|date('d.m.Y') }}{% if invoice.servicePeriodEnd %}–{{ invoice.servicePeriodEnd|date('d.m.Y') }}{% endif %}</td></tr>{% endif %}
        {% if invoice.recipientCustomerNumber %}<tr><td class="label">Ihre Kundennummer</td><td class="right">{{ invoice.recipientCustomerNumber }}</td></tr>{% endif %}
        {% if invoice.recipientVatId %}<tr><td class="label">USt-ID</td><td class="right">{{ invoice.recipientVatId }}</td></tr>{% endif %}
      </table>
    </div>
  </div>

  <h1>{{ title }} {{ invoice.number ?? '' }}</h1>
  {% if invoice.cancelsInvoice %}<div class="subtitle">Bezug: Rechnung {{ invoice.cancelsInvoice.number }} vom {{ invoice.cancelsInvoice.issueDate|date('d.m.Y') }}</div>{% endif %}

  {% if invoice.introText %}<div class="intro">{{ invoice.introText }}</div>{% endif %}

  <table class="items">
    <thead>
      <tr>
        <th class="pos">Pos.</th>
        <th>Beschreibung</th>
        <th class="r col-qty">Menge</th>
        <th class="r col-price">Einzelpreis</th>
        <th class="r col-total">Gesamtpreis</th>
      </tr>
    </thead>
    <tbody>
      {% set num = 0 %}
      {% for item in invoice.items %}
        {% set num = num + 1 %}
        <tr>
          <td class="pos">{{ num }}.</td>
          <td>
            <div class="item-title">{{ item.title }}</div>
            {% if item.description %}<div class="item-desc">{{ item.description }}</div>{% endif %}
          </td>
          <td class="r col-qty nums">{% if item.unit == 'pauschal' %}pauschal{% else %}{{ item.quantity|qty }}<br><span class="muted">{{ item.unit }}</span>{% endif %}</td>
          <td class="r col-price nums">{{ item.unitPrice|money }} {{ invoice.currency }}</td>
          <td class="r col-total nums">
            <strong>{{ item.lineGross|money }} {{ invoice.currency }}</strong>
            <div class="tax-note">{% if item.taxCategory.value == 'standard' %}(Steuer {{ item.vatRate|qty }}%){% else %}({{ item.taxCategory.value }}){% endif %}</div>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <table class="totals nums">
    <tr><td class="t-label">Gesamtbetrag netto</td><td class="right">{{ invoice.totalNet|money }} {{ invoice.currency }}</td></tr>
    {% for g in invoice.taxBreakdown %}
      {% if g.tax != 0 %}<tr><td class="t-label">zzgl. Umsatzsteuer {{ g.rate|qty }}%</td><td class="right">{{ g.tax|money }} {{ invoice.currency }}</td></tr>{% endif %}
    {% endfor %}
    <tr class="grand"><td>Gesamtbetrag brutto</td><td class="right">{{ invoice.totalGross|money }} {{ invoice.currency }}</td></tr>
    {% if invoice.paidAmount > 0 %}
      <tr><td class="t-label">bereits bezahlt</td><td class="right">−{{ invoice.paidAmount|money }} {{ invoice.currency }}</td></tr>
      <tr class="grand"><td>Offener Betrag</td><td class="right">{{ invoice.openAmount|money }} {{ invoice.currency }}</td></tr>
    {% endif %}
  </table>

  {% set notes = [] %}
  {% for item in invoice.items %}
    {% if item.taxCategory.legalNote and item.taxCategory.legalNote not in notes %}{% set notes = notes|merge([item.taxCategory.legalNote]) %}{% endif %}
  {% endfor %}
  {% if notes is not empty %}<div class="legal">{% for n in notes %}{{ n }}<br>{% endfor %}</div>{% endif %}

  {% if invoice.type.value == 'invoice' and company.iban and invoice.openAmount > 0 %}
    <div class="payinfo">
      Bitte überweisen Sie den Betrag von <strong>{{ invoice.openAmount|money }} {{ invoice.currency }}</strong>
      {% if invoice.dueDate %}bis zum <strong>{{ invoice.dueDate|date('d.m.Y') }}</strong>{% endif %}
      auf folgendes Konto:<br>
      {{ company.bankName }} · IBAN {{ company.iban }} · BIC {{ company.bic }}<br>
      Verwendungszweck: {{ invoice.number }}
    </div>
  {% endif %}

  {% if invoice.outroText %}<div class="outro">{{ invoice.outroText }}</div>{% endif %}
</body>
</html>
