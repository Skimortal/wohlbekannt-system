<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
  body { font-family: sans-serif; color: #0e1214; font-size: 10.5px; line-height: 1.45; }
  .muted { color: #6b7176; }
  .right { text-align: right; }
  .issuer-line { font-size: 8px; color: #6b7176; }
  .logo { width: 150px; }

  table.meta { width: 100%; border-collapse: collapse; }
  table.meta td { padding: 1px 0; vertical-align: top; }
  table.meta .label { color: #6b7176; padding-right: 16px; }

  h1 { font-size: 18px; font-weight: bold; margin: 22px 0 12px; }
  .intro { margin-bottom: 14px; }

  table.items { width: 100%; border-collapse: collapse; margin-top: 6px; }
  table.items thead th {
    text-align: left; font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.4px;
    color: #3a3f42; border-bottom: 1px solid #0e1214; padding: 6px 5px;
  }
  table.items thead th.r { text-align: right; }
  table.items td { padding: 8px 5px; vertical-align: top; border-bottom: 0.5px solid #ece8e2; }
  .pos { width: 42px; color: #3a3f42; }
  .col-qty { width: 78px; }
  .col-price { width: 88px; }
  .col-total { width: 96px; }
  .item-title { font-weight: bold; }
  .item-desc { color: #3a3f42; margin-top: 2px; }
  .tax-note { font-size: 8px; color: #6b7176; }

  tr.optional td { background-color: #faf3ea; color: #6b7176; }
  tr.optional .item-title { color: #3a3f42; }
  .opt-chip {
    font-size: 7.5px; font-weight: bold; color: #8a5a2e;
    background-color: #f3e6d6; border: 0.5px solid #e6c7a9;
    border-radius: 3px; padding: 1px 3px;
  }

  table.totals { width: 55%; border-collapse: collapse; margin-top: 12px; }
  table.totals td { padding: 4px 5px; }
  table.totals .t-label { color: #3a3f42; }
  table.totals tr.grand td { font-weight: bold; border-top: 1px solid #0e1214; }
  table.totals tr.optsum td { color: #6b7176; }

  .legal { margin-top: 12px; font-size: 9px; color: #3a3f42; }
  .outro { margin-top: 20px; }
</style>
</head>
<body>

  <table style="width:100%; border-collapse:collapse;">
    <tr>
      <td style="vertical-align:top;" class="issuer-line">
        {{ company.legalName }} &nbsp;·&nbsp; {{ company.address.street }} &nbsp;·&nbsp;
        {{ company.address.postalCode }} {{ company.address.city }}
      </td>
      <td style="width:160px; vertical-align:top; text-align:right;">
        {% if logoSrc %}<img class="logo" src="{{ logoSrc }}">{% endif %}
      </td>
    </tr>
  </table>

  <table style="width:100%; border-collapse:collapse; margin-top:22px;">
    <tr>
      <td style="vertical-align:top;">
        <strong>{{ quote.recipientName }}</strong><br>
        {% if quote.recipientAddress.street %}{{ quote.recipientAddress.street }}<br>{% endif %}
        {% if quote.recipientAddress.postalCode or quote.recipientAddress.city %}{{ quote.recipientAddress.postalCode }} {{ quote.recipientAddress.city }}<br>{% endif %}
        {{ quote.recipientAddress.countryCode == 'AT' ? 'Österreich' : quote.recipientAddress.countryCode }}
      </td>
      <td style="width:250px; vertical-align:top;">
        <table class="meta">
          <tr><td class="label">Angebots-Nr.</td><td class="right">{{ quote.number ?? 'Entwurf' }}</td></tr>
          <tr><td class="label">Datum</td><td class="right">{{ quote.issueDate|date('d.m.Y') }}</td></tr>
          {% if quote.validUntil %}<tr><td class="label">Gültig bis</td><td class="right">{{ quote.validUntil|date('d.m.Y') }}</td></tr>{% endif %}
          {% if quote.recipientCustomerNumber %}<tr><td class="label">Ihre Kundennummer</td><td class="right">{{ quote.recipientCustomerNumber }}</td></tr>{% endif %}
          {% if quote.contactPerson %}<tr><td class="label">Ihr Ansprechpartner</td><td class="right">{{ quote.contactPerson }}</td></tr>{% endif %}
        </table>
      </td>
    </tr>
  </table>

  <h1>Angebot {{ quote.number ?? '' }}</h1>

  {% if quote.introText %}<div class="intro">{{ quote.introText|nl2br }}</div>{% endif %}

  <table class="items">
    <thead>
      <tr>
        <th class="pos">Pos.</th>
        <th>Beschreibung</th>
        <th class="r col-qty">Menge</th>
        <th class="r col-price">Einzelpreis</th>
        <th class="r col-total">Gesamtpreis</th>
      </tr>
    </thead>
    <tbody>
      {% set num = 0 %}
      {% for item in quote.items %}
        {% if not item.optional %}{% set num = num + 1 %}{% endif %}
        <tr class="{{ item.optional ? 'optional' : '' }}">
          <td class="pos">{% if item.optional %}<span class="opt-chip">Opt.</span>{% else %}{{ num }}.{% endif %}</td>
          <td>
            <div class="item-title">{{ item.title }}</div>
            {% if item.description %}<div class="item-desc">{{ item.description|nl2br }}</div>{% endif %}
          </td>
          <td class="r col-qty">
            {% if item.unit == 'pauschal' %}pauschal{% else %}{{ item.quantity|qty }}<br><span class="muted">{{ item.unit }}</span>{% endif %}
          </td>
          <td class="r col-price">{{ item.unitPrice|money }} {{ quote.currency }}</td>
          <td class="r col-total">
            {% if item.optional %}({{ item.lineGross|money }} {{ quote.currency }}){% else %}<strong>{{ item.lineGross|money }} {{ quote.currency }}</strong>{% endif %}
            <div class="tax-note">{% if item.taxCategory.value == 'standard' %}(Steuer {{ item.vatRate|qty }}%){% else %}({{ item.taxCategory.value }}){% endif %}</div>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <table class="totals" align="right">
    <tr><td class="t-label">Gesamtbetrag netto</td><td class="right">{{ quote.totalNet|money }} {{ quote.currency }}</td></tr>
    {% for g in quote.taxBreakdown %}
      {% if g.tax > 0 %}<tr><td class="t-label">zzgl. Umsatzsteuer {{ g.rate|qty }}%</td><td class="right">{{ g.tax|money }} {{ quote.currency }}</td></tr>{% endif %}
    {% endfor %}
    <tr class="grand"><td>Gesamtbetrag brutto</td><td class="right">{{ quote.totalGross|money }} {{ quote.currency }}</td></tr>
    {% if quote.optionalTotalGross > 0 %}
      <tr class="optsum"><td>Summe optionaler Positionen brutto</td><td class="right">{{ quote.optionalTotalGross|money }} {{ quote.currency }}</td></tr>
    {% endif %}
  </table>

  {% set notes = [] %}
  {% for item in quote.items %}
    {% if item.taxCategory.legalNote and item.taxCategory.legalNote not in notes %}{% set notes = notes|merge([item.taxCategory.legalNote]) %}{% endif %}
  {% endfor %}
  {% if notes is not empty %}<div class="legal" style="clear:both;">{% for n in notes %}{{ n }}<br>{% endfor %}</div>{% endif %}

  {% if quote.outroText %}<div class="outro" style="clear:both;">{{ quote.outroText|nl2br }}</div>{% endif %}

</body>
</html>
